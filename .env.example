# ─── Heady Environment Configuration ────────────────────────────
# Copy to .env and fill in your keys

# ── Core ──
NODE_ENV=development
PORT=3301
LOG_LEVEL=info
DATA_DIR=/app/data

# ── Authentication ──
JWT_SECRET=your-jwt-secret-here
ADMIN_EMAIL=admin@headyme.com

# ── AI Providers ──
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
GOOGLE_GEMINI_API_KEY=xxx
GROQ_API_KEY=gsk_xxx
PERPLEXITY_API_KEY=pplx-xxx

# ── Ollama (local models) ──
OLLAMA_BASE_URL=http://localhost:11434

# ── MCP ──
MCP_BEARER_TOKEN=your-mcp-token
MCP_TRANSPORT=sse

# ── Cloudflare ──
CF_ACCOUNT_ID=xxx
CF_API_TOKEN=xxx
CF_KV_NAMESPACE_ID=xxx
CF_TUNNEL_TOKEN=xxx

# ── Google Cloud ──
GCP_PROJECT_ID=heady-prod
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcp-sa.json
VERTEX_AI_LOCATION=us-central1

# ── GitHub ──
GITHUB_TOKEN=ghp_xxx
GITHUB_WEBHOOK_SECRET=xxx

# ── Notion ──
NOTION_API_KEY=ntn_xxx
NOTION_DATABASE_ID=xxx

# ── Memory / Embeddings ──
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_DIMENSIONS=1536
MEMORY_PERSISTENCE=file

# ── Feature Flags ──
ENABLE_ARENA_MODE=true
ENABLE_AUTO_SUCCESS=true
ENABLE_MONTE_CARLO=true
ENABLE_SOUL_GOVERNANCE=true

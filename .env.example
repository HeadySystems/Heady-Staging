# ============================================================
# HEADY SYSTEM — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file to version control.
# Every secret listed here MUST come from environment variables
# or a secret manager — never hardcoded in source code.
#
# © 2026 HeadySystems Inc. — Sacred Geometry v4.0
# ============================================================

# ----- SECURITY (Required — system won't start without these) -----

# Signs all inter-agent JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=

# Signs inter-agent message envelopes (HMAC-SHA256). Generate with: openssl rand -hex 32
HMAC_SECRET=

# Redis connection string for the message bus. Format: redis://host:port/db
# For Redis Cluster: redis://host1:port1,host2:port2,host3:port3
REDIS_URL=

# CORS whitelist — comma-separated, explicit origins only. NO wildcards ('*').
# Example: https://app.headysystems.com,https://admin.headysystems.com
ALLOWED_ORIGINS=

# ----- RUNTIME IDENTITY -----

# Which Colab runtime this instance is. One of: cortex, synapse, reflex
# Cortex = A100 80GB (primary inference)
# Synapse = A100 40GB (vector ops, embeddings)
# Reflex = T4/L4 (lightweight agents, monitoring)
HEADY_RUNTIME=cortex

# Port for the local HTTP server (inter-runtime communication)
PORT=8001

# ----- TRADING APIs (Required for live trading, optional for paper) -----

# Tradovate API credentials
TRADOVATE_API_KEY=
TRADOVATE_API_SECRET=
TRADOVATE_ACCOUNT_ID=
TRADOVATE_ENVIRONMENT=demo  # 'demo' for paper trading, 'live' for real money

# Rithmic API credentials (market data)
RITHMIC_API_KEY=
RITHMIC_API_SECRET=
RITHMIC_ENVIRONMENT=paper  # 'paper' or 'live'

# TradersPost webhook URL for multi-account routing
TRADERSPOST_WEBHOOK_URL=

# PickMyTrade API key (Tradovate-authorized vendor alternative)
PICKMYTRADE_API_KEY=

# ----- MARKET DATA -----

# AlphaVantage API key for fundamental data and technical indicators
ALPHAVANTAGE_API_KEY=

# Databento API key for institutional-grade market data
DATABENTO_API_KEY=

# ----- AI / ML -----

# Anthropic API key (for Claude-based agent reasoning)
ANTHROPIC_API_KEY=

# OpenAI API key (fallback LLM backbone)
OPENAI_API_KEY=

# Hugging Face token (for model downloads on Colab runtimes)
HF_TOKEN=

# ----- INFRASTRUCTURE -----

# PostgreSQL connection string for persistent storage
# Format: postgresql://user:password@host:port/database
DATABASE_URL=

# Google Drive mount path for state checkpoints
CHECKPOINT_DIR=/content/drive/MyDrive/heady/checkpoints

# ----- OBSERVABILITY -----

# Grafana Cloud or self-hosted metrics endpoint
GRAFANA_URL=
GRAFANA_API_KEY=

# OpenTelemetry collector endpoint for distributed tracing
OTEL_EXPORTER_OTLP_ENDPOINT=

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ----- APEX TRADER FUNDING (account-specific) -----

# Account size determines drawdown limits and contract maximums
APEX_ACCOUNT_SIZE=50000
APEX_MAX_DRAWDOWN=2500
APEX_MAX_CONTRACTS=10

# Trading mode: paper (default, safe) or live (real money, requires explicit opt-in)
TRADING_MODE=paper

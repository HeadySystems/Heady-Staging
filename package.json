{
  "name": "heady-latent-os",
  "version": "3.2.0",
  "description": "Self-aware, self-correcting intelligence infrastructure \u2014 the Heady Latent OS",
  "main": "heady-manager.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node heady-manager.js",
    "dev": "node --watch heady-manager.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .js,.mjs",
    "lint:fix": "eslint src/ --ext .js,.mjs --fix",
    "build:frontend": "cd frontend && vite build",
    "docker:build": "podman build -t heady:latest .",
    "docker:run": "podman run -d -p 3301:3301 -v heady-data:/app/data heady:latest",
    "health": "curl -s http://localhost:3301/health | jq",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "audit:fix": "npm audit fix --force"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "dotenv": "^16.4.5",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "eventsource": "^3.0.2",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.0",
    "ioredis": "^5.4.1",
    "@anthropic-ai/sdk": "^0.32.0",
    "openai": "^4.68.0",
    "@google/generative-ai": "^0.21.0",
    "groq-sdk": "^0.7.0",
    "ollama": "^0.5.11",
    "langchain": "^0.3.6",
    "@notionhq/client": "^2.2.15"
  },
  "devDependencies": {
    "vitest": "^2.1.3",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "@types/node": "^22.8.0",
    "nodemon": "^3.1.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HeadyMe/Heady-8f71ffc8.git"
  },
  "author": "HeadySystems Inc.",
  "license": "UNLICENSED"
}